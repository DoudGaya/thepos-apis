generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                @id @default(cuid())
  email                    String                @unique
  phone                    String?               @unique
  firstName                String?
  lastName                 String?
  passwordHash             String?
  isVerified               Boolean               @default(false)
  referralCode             String                @unique
  referredBy               String?
  credits                  Float                 @default(0)
  role                     Role                  @default(USER)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  pinHash                  String?
  adminRoleId              String?
  hasFundedWallet          Boolean               @default(false)
  passiveReferralGroupId   String?
  pushToken                String?
  emailVerified            DateTime?
  phoneVerified            Boolean               @default(false)
  accounts                 Account[]
  receivedRequests         MoneyRequest[]        @relation("ReceivedRequests")
  sentRequests             MoneyRequest[]        @relation("SentRequests")
  notifications            Notification[]
  referralEarningsReferred ReferralEarning[]     @relation("ReferralEarningReferred")
  referralEarnings         ReferralEarning[]
  referredUsers            Referral[]            @relation("ReferredUser")
  referrals                Referral[]            @relation("ReferrerUser")
  rewardHistory            RewardHistory[]
  sessions                 Session[]
  subscriptions            Subscription[]
  transactions             Transaction[]
  receivedTransfers        Transfer[]            @relation("ReceivedTransfers")
  sentTransfers            Transfer[]            @relation("SentTransfers")
  targetProgress           UserTargetProgress[]
  adminRole                AdminRole?            @relation(fields: [adminRoleId], references: [id])
  passiveReferralGroup     PassiveReferralGroup? @relation(fields: [passiveReferralGroupId], references: [id])

  @@map("users")
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@map("admin_roles")
}

model FixedReferralRule {
  id               String                 @id @default(cuid())
  name             String
  description      String?
  commissionType   ReferralCommissionType
  commissionValue  Float
  minFundingAmount Float                  @default(0)
  isActive         Boolean                @default(true)
  audience         TargetAudience         @default(ALL)
  specificUserIds  Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@map("fixed_referral_rules")
}

model PassiveReferralGroup {
  id                String   @id @default(cuid())
  name              String   @unique
  description       String?
  commissionPercent Float
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  users             User[]

  @@map("passive_referral_groups")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  type             TransactionType
  amount           Float
  status           TransactionStatus @default(PENDING)
  reference        String            @unique
  details          Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  costPrice        Float             @default(0)
  idempotencyKey   String?           @unique
  network          String?
  profit           Float             @default(0)
  recipient        String?
  sellingPrice     Float             @default(0)
  vendorCallAt     DateTime?
  vendorName       String?
  vendorReference  String?
  vendorResponse   Json?
  vendorResponseAt DateTime?
  vendorStatus     String?
  referralEarnings ReferralEarning[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@map("transactions")
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  type        SubscriptionType
  amount      Float
  frequency   SubscriptionFreq   @default(MONTHLY)
  status      SubscriptionStatus @default(ACTIVE)
  details     Json
  nextRenewal DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referredId String
  reward     Float    @default(100)
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  referred   User     @relation("ReferredUser", fields: [referredId], references: [id], onDelete: Cascade)
  referrer   User     @relation("ReferrerUser", fields: [referrerId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
  @@map("referrals")
}

model ReferralEarning {
  id             String       @id @default(cuid())
  userId         String
  referredUserId String?
  transactionId  String?
  amount         Float
  type           String
  status         String       @default("PENDING")
  description    String?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  referredUser   User?        @relation("ReferralEarningReferred", fields: [referredUserId], references: [id])
  transaction    Transaction? @relation(fields: [transactionId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("referral_earnings")
}

model OTP {
  id        String   @id @default(cuid())
  phone     String
  code      String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otps")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(GENERAL)
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Pricing {
  id           String   @id @default(cuid())
  service      String
  network      String
  profitMargin Float    @default(2.5)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([service, network])
  @@map("pricing")
}

model VendorConfig {
  id                      String           @id @default(cuid())
  vendorName              String           @unique
  isEnabled               Boolean          @default(true)
  isPrimary               Boolean          @default(false)
  priority                Int              @default(0)
  supportsAirtime         Boolean          @default(true)
  supportsData            Boolean          @default(true)
  supportsElectric        Boolean          @default(false)
  supportsCableTV         Boolean          @default(false)
  supportsBetting         Boolean          @default(false)
  supportsEPINS           Boolean          @default(false)
  credentials             Json
  lastHealthCheck         DateTime?
  isHealthy               Boolean          @default(true)
  failureCount            Int              @default(0)
  lastFailure             DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  adapterId               String           @unique
  balance                 Float            @default(0)
  type                    VendorType       @default(ALL)
  dataPlans               DataPlan[]
  serviceRoutingsFallback ServiceRouting[] @relation("FallbackVendor")
  serviceRoutingsPrimary  ServiceRouting[] @relation("PrimaryVendor")

  @@map("vendor_configs")
}

model ServiceRouting {
  id               String          @id @default(cuid())
  serviceType      TransactionType
  network          String
  primaryVendorId  String
  fallbackVendorId String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  fallbackVendor   VendorConfig?   @relation("FallbackVendor", fields: [fallbackVendorId], references: [id])
  primaryVendor    VendorConfig    @relation("PrimaryVendor", fields: [primaryVendorId], references: [id])

  @@unique([serviceType, network])
  @@map("service_routings")
}

model DataPlan {
  id           String       @id @default(cuid())
  planId       String
  network      String
  planType     String
  size         String
  validity     String
  vendorId     String
  costPrice    Float
  sellingPrice Float
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  vendor       VendorConfig @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, planId])
  @@map("data_plans")
}

model ProfitMargin {
  id          String   @id @default(cuid())
  service     String
  vendorName  String?
  marginType  String
  marginValue Float
  minAmount   Float?
  maxAmount   Float?
  network     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([service, vendorName, network])
  @@map("profit_margins")
}

model AmigoPlans {
  id                 String   @id @default(cuid())
  planId             Int      @unique
  networkName        String
  dataCapacity       String
  dataCapacityValue  Float
  validityDays       Int
  validityLabel      String
  amigoBasePrice     Float
  adminOverridePrice Float?
  pricePerGB         Float
  efficiencyRating   Float    @default(100)
  isEnabled          Boolean  @default(true)
  margin             Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([planId, networkName])
  @@index([networkName])
  @@index([isEnabled])
  @@map("amigo_plans")
}

model Transfer {
  id         String         @id @default(cuid())
  senderId   String
  receiverId String
  amount     Float
  status     TransferStatus @default(PENDING)
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  receiver   User           @relation("ReceivedTransfers", fields: [receiverId], references: [id])
  sender     User           @relation("SentTransfers", fields: [senderId], references: [id])

  @@map("transfers")
}

model MoneyRequest {
  id          String             @id @default(cuid())
  requesterId String
  payerId     String
  amount      Float
  status      MoneyRequestStatus @default(PENDING)
  note        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  payer       User               @relation("ReceivedRequests", fields: [payerId], references: [id])
  requester   User               @relation("SentRequests", fields: [requesterId], references: [id])

  @@map("money_requests")
}

model SalesTarget {
  id                String               @id @default(cuid())
  title             String
  description       String?
  type              TargetType
  period            TargetPeriod
  targetValue       Float
  rewardAmount      Float
  audience          TargetAudience       @default(ALL)
  specificUserIds   Json?
  tierType          TierType             @default(SINGLE)
  tiers             Json?
  startDate         DateTime?
  endDate           DateTime?
  isRecurring       Boolean              @default(true)
  serviceType       TransactionType?
  network           String?
  isActive          Boolean              @default(true)
  isVisible         Boolean              @default(true)
  priority          Int                  @default(0)
  totalParticipants Int                  @default(0)
  totalCompletions  Int                  @default(0)
  totalRewardsPaid  Float                @default(0)
  createdBy         String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  progress          UserTargetProgress[]

  @@map("sales_targets")
}

model UserTargetProgress {
  id               String      @id @default(cuid())
  userId           String
  targetId         String
  currentValue     Float       @default(0)
  currentTier      Int?
  isClaimed        Boolean     @default(false)
  claimedAt        DateTime?
  claimedAmount    Float       @default(0)
  periodStart      DateTime
  periodEnd        DateTime
  firstProgressAt  DateTime?
  lastProgressAt   DateTime?
  transactionCount Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  target           SalesTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId, periodStart])
  @@index([userId, isClaimed])
  @@index([targetId, periodStart])
  @@map("user_target_progress")
}

model RewardHistory {
  id            String   @id @default(cuid())
  userId        String
  targetId      String
  progressId    String   @unique
  amount        Float
  tier          Int?
  tierName      String?
  transactionId String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([targetId, createdAt])
  @@map("reward_history")
}

enum ReferralCommissionType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum VendorType {
  DATA
  AIRTIME
  UTILITY
  ALL
}

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  DATA
  AIRTIME
  ELECTRICITY
  CABLE
  CABLE_TV
  WATER
  BETTING
  EPINS
  CREDIT_PURCHASE
  REFERRAL_BONUS
  WALLET_FUNDING
  P2P_TRANSFER
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  COMPLETED
}

enum SubscriptionType {
  DATA
  ELECTRICITY
  CABLE
}

enum SubscriptionFreq {
  MONTHLY
  WEEKLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum NotificationType {
  GENERAL
  TRANSACTION
  PROMOTION
  SYSTEM
  SECURITY
}

enum TierType {
  SINGLE
  MULTIPLE
}

enum TargetPeriod {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum TargetAudience {
  ALL
  SPECIFIC
}

enum TransferStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  COMPLETED
}

enum MoneyRequestStatus {
  PENDING
  PAID
  DECLINED
  CANCELLED
}

enum TargetType {
  AMOUNT_SPENT
  TRANSACTION_COUNT
  DATA_VOLUME
}
